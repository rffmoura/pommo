{
  "expo": {
    "name": "pommo",
    "slug": "pommo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f0f14"
    },
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "UIBackgroundModes": [
          "audio",
          "fetch",
          "remote-notification",
          "audio",
          "fetch",
          "remote-notification"
        ],
        "NSUserNotificationUsageDescription": "Usado para avisar quando o timer terminar.",
        "NSMicrophoneUsageDescription": "Não utilizado.",
        "NSSpeechRecognitionUsageDescription": "Não utilizado.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.pommo.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f0f14"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.USE_EXACT_ALARM",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.WAKE_LOCK",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "package": "com.pommo.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#ff6b6b",
          "defaultChannel": "timer",
          "sounds": [
            "./src/assets/sounds/blim.wav"
          ]
        }
      ],
      "expo-av"
    ],
    "extra": {
      "eas": {
        "projectId": "e9e7cd93-662d-4723-8b6b-0152feacc7ff"
      }
    }
  }
}
